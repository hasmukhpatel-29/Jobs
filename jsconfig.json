{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": ["app/components/*"],
      "@config/*": ["app/config/*"],
      "@screens/*": ["app/screens/*"],
      "@assets/*": ["app/assets/*"],
      "@navigation/*": ["app/navigation/*"],
      "@contexts/*": ["app/contexts/*"],
      "@utils/*": ["app/utils/*"],
      "@zustand/*": ["app/zustand/*"],
      "@zod/*": ["app/zod/*"],
      "@apis/*": ["app/Apis/*"],
      "@apiRoutes/*": ["app/Apis/ApiRoutes/*"],
      "@endPoints/*": ["app/Apis/EndPoints/*"],
    }
  },
  "exclude": ["node_modules"]
}